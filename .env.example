# Copy to .env.local for local dev — never commit real values

# Database (same Postgres as RedDirt — civic_call schema only)
DATABASE_URL=

# Admin moderation API
CIVIC_CALL_ADMIN_TOKEN=

# Google Maps — browser (Maps JavaScript API, referrer-restricted)
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps — server only (Geocoding API, IP-restricted; Netlify Functions)
GOOGLE_MAPS_GEOCODING_API_KEY=

# Optional — event harvester scripts (local/CI only, not required for site build)
# BING_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Optional: force bundled seed data in dev
# VITE_USE_SEED=true
