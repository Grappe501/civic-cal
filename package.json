{
  "name": "arkansas-everywhere",
  "version": "0.1.0",
  "private": true,
  "description": "Arkansas Everywhere — statewide civic + community events calendar",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/assert-h-drive.cjs",
    "dev": "node scripts/run-with-h-drive-env.cjs vite",
    "build": "node scripts/run-with-h-drive-env.cjs vite build",
    "preview": "node scripts/run-with-h-drive-env.cjs vite preview",
    "typecheck": "node scripts/run-with-h-drive-env.cjs tsc --noEmit",
    "seed:sync": "node scripts/run-with-h-drive-env.cjs node scripts/sync-seed-from-reddirt.cjs",
    "seed:import": "node scripts/run-with-h-drive-env.cjs node scripts/import-seed-to-db.cjs",
    "seed:geocode": "node scripts/run-with-h-drive-env.cjs node scripts/geocode-seed-events.mjs",
    "harvest:city": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/harvest-city.mjs",
    "harvest:priority-cities": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/harvest-all-priority-cities.mjs",
    "harvest:flagship": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/sources/dolr-events.mjs",
    "harvest:dedupe": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/dedupe-event-candidates.mjs",
    "harvest:registry": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/sync-recurring-registry.mjs",
    "harvest:top200": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/harvest-top-200.mjs",
    "harvest:november": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/harvest-through-november.mjs",
    "discover:sources": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/discover-city-sources.mjs",
    "generate:top200-cities": "node scripts/run-with-h-drive-env.cjs node scripts/event-harvest/generate-top-200-cities.mjs",
    "generate:local-intelligence": "node scripts/run-with-h-drive-env.cjs node scripts/generate-local-intelligence-registry.mjs",
    "generate:institutions": "node scripts/run-with-h-drive-env.cjs node scripts/generate-community-institutions.mjs",
    "generate:community-anchors": "node scripts/run-with-h-drive-env.cjs node scripts/generate-community-anchors.mjs",
    "generate:state-dates": "node scripts/run-with-h-drive-env.cjs node scripts/state-dates/generate-state-dates.mjs",
    "import:state-dates": "node scripts/run-with-h-drive-env.cjs node scripts/state-dates/import-state-dates.mjs",
    "harvest:food-trucks": "node scripts/run-with-h-drive-env.cjs node scripts/food-truck/harvest-food-trucks.mjs",
    "generate:public-demo-seed": "node scripts/generate-public-demo-seed.mjs",
    "import:candidates": "node scripts/run-with-h-drive-env.cjs node scripts/import-ingestion-candidates.cjs",
    "lint": "eslint src --ext ts,tsx",
    "audit:contrast": "node scripts/run-with-h-drive-env.cjs node scripts/audit-contrast.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.6",
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.562.0",
    "pg": "^8.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@netlify/functions": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.5.0",
    "vite": "^5.4.11"
  }
