{
  "name": "arkansas-everywhere",
  "version": "0.1.0",
  "private": true,
  "description": "Arkansas Everywhere — statewide civic + community events calendar",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/assert-h-drive.cjs",
    "dev": "node scripts/run-with-h-drive-env.cjs vite",
    "build": "node scripts/run-with-h-drive-env.cjs vite build",
    "preview": "node scripts/run-with-h-drive-env.cjs vite preview",
    "typecheck": "node scripts/run-with-h-drive-env.cjs tsc --noEmit",
    "seed:sync": "node scripts/run-with-h-drive-env.cjs node scripts/sync-seed-from-reddirt.cjs",
    "seed:import": "node scripts/run-with-h-drive-env.cjs node scripts/import-seed-to-db.cjs",
    "seed:geocode": "node scripts/run-with-h-drive-env.cjs node scripts/geocode-seed-events.mjs",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.6",
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.562.0",
    "pg": "^8.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@netlify/functions": "^3.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.5.0",
    "vite": "^5.4.11"
  }
}
