{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecurrenceExtraction",
  "type": "object",
  "required": ["recurrence", "confidence", "uncertainty", "missingFields"],
  "properties": {
    "recurrence": {
      "type": ["object", "null"],
      "properties": {
        "pattern": { "type": "string", "enum": ["monthly", "weekly", "annual", "unknown"] },
        "weekOfMonth": { "type": ["integer", "null"] },
        "weekday": { "type": ["string", "null"] },
        "time": { "type": ["string", "null"] }
      }
    },
    "venue": { "type": ["string", "null"] },
    "address": { "type": ["string", "null"] },
    "city": { "type": ["string", "null"] },
    "county": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "uncertainty": { "type": "array", "items": { "type": "string" } },
    "missingFields": { "type": "array", "items": { "type": "string" } },
    "suggestedFutureDates": { "type": "array", "items": { "type": "string", "format": "date" } },
    "facts": { "type": "array", "items": { "type": "string" } },
    "inferences": { "type": "array", "items": { "type": "string" } }
  }
}
