      "label": "Extension / 4-H / Homemakers",
      "registryLane": "community_anchors"
    },
    {
      "lane": 7,
      "id": "vfds",
      "label": "Volunteer Fire Departments",
      "coverage": ["fish_fries", "pancake_breakfasts", "cookoffs", "fundraisers", "parades"],
      "registryLane": "vfds"
    },
    {
      "lane": 8,
      "id": "churches",
      "label": "Church Community Events",
      "goal": { "annual_events": 5000 },
      "coverage": ["fish_fries", "spaghetti_suppers", "wild_game_dinners", "fall_festivals", "vbs"],
