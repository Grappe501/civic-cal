  "sixMonthPriority": [
    { "order": 1, "laneId": "county_fairs", "label": "County fair lane completion" },
    { "order": 2, "laneId": "festivals", "label": "Festival lane (top 250 cities)" },
    { "order": 3, "laneId": "government_civic", "label": "Government meetings" },
    { "order": 4, "laneId": "schools", "label": "School boards & athletics" },
    { "order": 5, "laneId": "community_anchors", "label": "Extension / 4-H / Homemakers" },
    { "order": 6, "laneId": "vfds", "label": "Volunteer fire departments" },
    { "order": 7, "laneId": "churches", "label": "Community church events" },
    { "order": 8, "laneId": "civic_orgs", "label": "Chambers / Rotary / Lions" },
