{
  "version": "2.0",
  "title": "Master Calendar Lane Map",
  "updatedAt": "2026-06-21",
  "objective": "Build the definitive civic, community, cultural, educational, recreational, and political event graph for Arkansas.",
  "productStack": [
    "Arkansas Everywhere",
    "Best Arkansas Community Calendar",
    "Best Arkansas Event Database",
    "Best Arkansas Community Knowledge Graph",
    "Best Arkansas Civic Intelligence Engine",
    "Campaign tools (admin-only, on top)"
  ],
  "buildProgram": {
    "stopUntilDensity": ["campaign_features", "paid_features", "crm_features"],
    "focus": ["density", "content", "drill_down_pages", "lanes", "narratives", "internal_links", "ai_knowledge"]
  },
  "tenLaneProgram": [
    {
      "lane": 1,
      "id": "government_civic",
      "label": "Government Meetings",
      "goal": { "counties": 75, "cities": 250 },
      "coverage": ["quorum_courts", "city_councils", "planning_commissions", "school_boards", "election_commissions"],
      "registryLane": "government_civic"
    },
    {
      "lane": 2,
      "id": "schools",
      "label": "Public Schools",
      "goal": { "high_schools": 328, "events": 1000 },
