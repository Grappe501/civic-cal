      "registryLane": "schools"
    },
    {
      "lane": 3,
      "id": "colleges",
      "label": "Colleges & Universities",
      "goal": { "institutions": 18, "annual_events": 500 },
      "coverage": ["athletics", "lectures", "student_activities"],
      "registryLane": "colleges"
    },
    {
      "lane": 4,
      "id": "county_fairs",
