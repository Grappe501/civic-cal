  "postHarvestStandard": [
    "harvest",
    "approve source-backed records",
    "rebuild AI indexes",
    "regenerate research tasks",
    "geocode approved bundles when API key present",
    "build narrative scaffolds",
    "build",
    "push"
  ],
  "aiBrainQuestions": [
    "Where should I be today?",
    "What are the highest value events this week?",
    "What relationships am I neglecting this month?",
    "What counties am I ignoring long term?",
